---
// Hidden easter egg — trigger with Konami code: ↑ ↑ ↓ ↓ ← → ← → B A
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>rip and tear</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://br.cdn.dos.zone/js-dos/nightly/js-dos.css" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      html, body {
        height: 100%;
        background: #0a0a0a;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: monospace;
        color: #cc0000;
        gap: 0.75rem;
      }

      .label {
        font-size: 0.7rem;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        opacity: 0.4;
      }

      #dos-wrap {
        position: relative;
        width: min(640px, 100vw);
        aspect-ratio: 4 / 2.5;
        background: #000;
        border: 1px solid rgba(204, 0, 0, 0.15);
      }

      #dos {
        width: 100%;
        height: 100%;
      }

      #overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        background: rgba(0, 0, 0, 0.82);
        cursor: pointer;
        transition: opacity 0.3s;
        z-index: 10;
      }

      #overlay:hover { background: rgba(0, 0, 0, 0.72); }

      .doom-title {
        font-size: clamp(2rem, 8vw, 3.5rem);
        letter-spacing: 0.2em;
        color: #cc0000;
        text-shadow: 0 0 30px rgba(204, 0, 0, 0.6);
      }

      .click-prompt {
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        color: rgba(204, 0, 0, 0.55);
        animation: blink 1.2s step-end infinite;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
      }

      .exit {
        font-size: 0.65rem;
        letter-spacing: 0.25em;
        color: rgba(204, 0, 0, 0.35);
        text-decoration: none;
        transition: color 0.2s;
      }
      .exit:hover { color: rgba(204, 0, 0, 0.7); }
    </style>
  </head>

  <body>
    <span class="label">you weren't supposed to find this</span>

    <div id="dos-wrap">
      <div id="overlay">
        <div class="doom-title">DOOM</div>
        <div class="click-prompt">click to play</div>
      </div>
      <div id="dos"></div>
    </div>

    <a href="/" class="exit">← escape</a>

    <script src="https://br.cdn.dos.zone/js-dos/nightly/js-dos.js"></script>
    <script>
      const overlay = document.getElementById('overlay');
      const dosEl = document.getElementById('dos');
      let started = false;

      overlay.addEventListener('click', () => {
        if (started) return;
        started = true;
        overlay.style.opacity = '0';
        overlay.style.pointerEvents = 'none';
        setTimeout(() => overlay.remove(), 300);

        Dos(dosEl, {
          url: '/doom.jsdos',
          renderAspect: '4/3',
        });
      });
    </script>
  </body>
</html>
