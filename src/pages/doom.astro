---
// Hidden easter egg — trigger with Konami code: ↑ ↑ ↓ ↓ ← → ← → B A
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>rip and tear</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://v8.js-dos.com/latest/js-dos.css" />
    <style>
      *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: #0a0a0a;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        font-family: monospace;
      }

      #game-wrap {
        position: relative;
        width: 640px;
        height: 400px;
        max-width: 100vw;
      }

      #dos {
        width: 100%;
        height: 100%;
      }

      #overlay {
        position: absolute;
        inset: 0;
        z-index: 100;
        background: #000;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.25rem;
        cursor: pointer;
        border: 1px solid rgba(180, 0, 0, 0.2);
      }

      #overlay-title {
        font-size: 4rem;
        font-weight: bold;
        letter-spacing: 0.15em;
        color: #cc0000;
        text-shadow: 0 0 40px rgba(204, 0, 0, 0.5);
        font-family: monospace;
      }

      #overlay-prompt {
        font-size: 0.7rem;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: rgba(204, 0, 0, 0.55);
        animation: blink 1.2s step-end infinite;
        font-family: monospace;
      }

      @keyframes blink {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0; }
      }

      #top-label {
        font-size: 0.65rem;
        letter-spacing: 0.35em;
        text-transform: uppercase;
        color: rgba(204, 0, 0, 0.3);
        font-family: monospace;
      }

      #exit-link {
        font-size: 0.65rem;
        letter-spacing: 0.25em;
        color: rgba(204, 0, 0, 0.3);
        text-decoration: none;
        font-family: monospace;
        transition: color 0.2s;
      }

      #exit-link:hover { color: rgba(204, 0, 0, 0.65); }
    </style>
  </head>

  <body>
    <span id="top-label">you weren't supposed to find this</span>

    <div id="game-wrap">
      <div id="overlay">
        <div id="overlay-title">DOOM</div>
        <div id="overlay-prompt">click to play</div>
      </div>
      <div id="dos"></div>
    </div>

    <a id="exit-link" href="/">← escape</a>

    <script src="https://v8.js-dos.com/latest/js-dos.js"></script>
    <script>
      document.getElementById('overlay').addEventListener('click', function () {
        this.style.display = 'none';
        Dos(document.getElementById('dos'), {
          url: '/doom.jsdos',
        });
      });
    </script>
  </body>
</html>
